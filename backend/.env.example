# ============================================================================
#  VENOM AI — Environment Configuration Template
# ============================================================================
#
#  HOW TO USE:
#    1. Copy this file to ".env"        →  cp .env.example .env   (Linux/Mac)
#                                          copy .env.example .env  (Windows)
#    2. Fill in the values marked [REQUIRED]. [OPTIONAL] ones can stay blank.
#    3. Save. Then run:  docker compose up --build
#
#  ⚠  NEVER commit your real ".env" to git. It is already in .gitignore.
#     This ".env.example" is safe to commit — it has NO real secrets.
#
#  API KEYS AT A GLANCE:
#    ┌──────────────┬───────────┬──────────────────────────────────────────┐
#    │ Key          │ Required? │ What it powers                           │
#    ├──────────────┼───────────┼──────────────────────────────────────────┤
#    │ GROQ_API_KEY │ REQUIRED  │ AI: attack planning, vuln explanations,  │
#    │              │           │ code fixes, chatbot, attack narratives   │
#    │ VIRUSTOTAL   │ OPTIONAL  │ Threat intel: URL/IP/hash reputation     │
#    │ RESEND       │ OPTIONAL  │ Email verification + password reset      │
#    │ SMTP (Gmail) │ OPTIONAL  │ Alt email sender (if not using Resend)   │
#    │ GOOGLE OAuth │ OPTIONAL  │ "Sign in with Google" button             │
#    └──────────────┴───────────┴──────────────────────────────────────────┘
#
#  You only NEED a Groq key to use the scanner with AI features. Everything
#  else is optional. The scanner engines themselves work WITHOUT any key —
#  you just won't get AI explanations/fixes without Groq.
# ============================================================================


# ── Database (leave as-is for Docker) ──────────────────────────────────────
# These match the docker-compose.yml services. Only change if you run your
# own external Postgres/Redis.
DATABASE_URL=postgresql://cyberuser:cyberpass@postgres:5432/cyberplatform

# ── Redis / Celery (leave as-is for Docker) ────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# ===========================================================================
#  GROQ AI  —  [REQUIRED for AI features]
# ===========================================================================
#  Groq gives you FREE, fast LLM inference. VENOM uses it for:
#    - Planning which attacks to run against a target
#    - Explaining each vulnerability in plain English
#    - Generating a working code FIX in your app's language
#    - The built-in security chatbot
#    - Attack-chain narratives ("how a hacker would exploit this")
#
#  GET A KEY (free, 2 minutes):
#    1. Go to  https://console.groq.com
#    2. Sign up (free - no credit card)
#    3. Left menu -> "API Keys" -> "Create API Key"
#    4. Copy it and paste below as GROQ_API_KEY
#
#  ── KEY ROTATION (why there are 4 slots) ─────────────────────────────────
#  Groq's free tier has PER-KEY rate limits (~1,000 requests/min per key).
#
#  VENOM supports up to 4 keys. It tries GROQ_API_KEY first; if that key is
#  rate-limited (HTTP 429), it automatically falls through to KEY_2, then
#  KEY_3, then KEY_4. This multiplies your quota by up to 4x for free.
#
#  You only NEED one key (GROQ_API_KEY). The other 3 are optional - add them
#  only if you hit rate limits during heavy scanning. To add more, just make
#  extra free accounts / keys at console.groq.com.
#
#  ── Which model? ─────────────────────────────────────────────────────────
#  GROQ_MODEL       = the "smart" model used for planning + code fixes
#  GROQ_MODEL_FAST  = the "fast" model used for short replies + voice agent
#  Both defaults below are FREE production models on Groq. See the full list
#  at https://console.groq.com/docs/models — prefer "Production" models
#  (Preview models can be discontinued at short notice).
#
#  NOTE: llama-3.1-8b-instant is deprecated by Groq (decommission Aug 2026);
#  the defaults below are the current free replacements.
# ===========================================================================
GROQ_API_KEY=paste_your_groq_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MODEL_FAST=openai/gpt-oss-20b


# ===========================================================================
#  AUTH / JWT  —  [REQUIRED - generate your own random secrets]
# ===========================================================================
#  These sign login tokens. They MUST be long random strings unique to your
#  install. NEVER use the example values below in production.
#
#  GENERATE STRONG SECRETS (run either command, paste the output):
#    Python:   python -c "import secrets; print(secrets.token_hex(64))"
#    OpenSSL:  openssl rand -hex 64
#
#  Run it TWICE - once for SECRET_KEY, once for JWT_REFRESH_SECRET.
# ===========================================================================
SECRET_KEY=CHANGE_ME_run_python_c_import_secrets_print_secrets_token_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_second_different_token_hex_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
EMAIL_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_HOURS=1


# ── Frontend URL (used inside verification / reset email links) ────────────
#  Docker default is http://localhost:3000. Change to your domain in prod.
FRONTEND_URL=http://localhost:3000


# ===========================================================================
#  SINGLE-USER MODE  —  [open-source default]
# ===========================================================================
#  true   = No login, no email verification. VENOM opens straight to the
#           dashboard as one local user. Best for running it on your own
#           machine (like OWASP ZAP / Burp).
#  false  = Full multi-user login system with signup/login. Use this if a
#           small team shares one self-hosted instance.
# ===========================================================================
SINGLE_USER_MODE=true


# ===========================================================================
#  RESEND - Email Sending  -  [OPTIONAL]
# ===========================================================================
#  Only needed if you want email verification + password-reset emails.
#  If left blank, VENOM still works - users just won't get emails
#  (you can manually verify accounts, or use single-user mode).
#
#  GET A KEY (free tier: 3,000 emails/month):
#    1. Go to  https://resend.com  -> sign up
#    2. "API Keys" -> "Create API Key" (Full Access)
#    3. Paste below.
# ===========================================================================
RESEND_API_KEY=
EMAIL_FROM=VENOM AI <onboarding@resend.dev>


# ===========================================================================
#  GOOGLE OAUTH - "Sign in with Google"  -  [OPTIONAL]
# ===========================================================================
#  Leave blank to hide the Google login button (email/password still works).
#
#  SETUP (if you want it):
#    1. https://console.cloud.google.com -> create/select a project
#    2. "APIs & Services" -> "Credentials" -> "Create OAuth client ID"
#    3. Type: Web application
#    4. Authorized redirect URI:  http://localhost:8000/api/auth/google/callback
#    5. Copy the Client ID + Client Secret below.
# ===========================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback


# ===========================================================================
#  SMTP (Gmail)  -  Alternative Email Sender  -  [OPTIONAL]
# ===========================================================================
#  Only used if RESEND_API_KEY is blank and you'd rather send via Gmail.
#  Also used for monitoring alert emails (if you enable them).
#
#  SETUP (Gmail App Password):
#    1. Enable 2-Step Verification on the Google account
#    2. https://myaccount.google.com -> Security -> App Passwords
#    3. Generate a 16-char password for "Mail", paste below (no spaces).
# ===========================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=VENOM AI


# ===========================================================================
#  VIRUSTOTAL - Threat Intelligence  -  [OPTIONAL]
# ===========================================================================
#  Powers the Threat Intel tab (check if a URL/IP/domain/file-hash is
#  malicious against 70+ antivirus engines). Scanner works without it.
#
#  GET A KEY (free: 500 lookups/day):
#    1. https://www.virustotal.com -> sign up
#    2. Profile icon -> "API key" -> copy -> paste below.
# ===========================================================================
VIRUSTOTAL_API_KEY=


# ===========================================================================
#  TAVILY - Accurate AI Web Search  -  [OPTIONAL]
# ===========================================================================
#  When set, the VENOM AI chat uses Tavily as its PRIMARY web search (accurate,
#  AI-optimized results + a direct answer). Without it, VENOM falls back to the
#  free Google News / HackerNews / Wikipedia search (no key needed).
#
#  GET A KEY (free: 1,000 searches/month):
#    1. https://tavily.com -> sign up
#    2. Dashboard -> copy your API key (starts with "tvly-") -> paste below.
# ===========================================================================
TAVILY_API_KEY=


# ── File Storage (leave as-is) ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
MAX_FILE_SIZE_MB=20


# ===========================================================================
#  ENVIRONMENT  -  [IMPORTANT]
# ===========================================================================
#  "development"  -> API docs at /api/docs are ENABLED (use on your laptop)
#  "production"   -> API docs are DISABLED (use when hosting publicly)
# ===========================================================================
ENV=development


# ── CORS - who is allowed to call the API (comma-separated) ────────────────
#  Dev default below is fine. In production set it to your real domain only.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
