# ============================================================================
#  VENOM AI — Environment Configuration Template
# ============================================================================
#
#  HOW TO USE:
#    1. Copy this file to ".env"        →  cp .env.example .env   (Linux/Mac)
#                                          copy .env.example .env  (Windows)
#    2. Fill in the values marked [REQUIRED]. [OPTIONAL] ones can stay blank.
#    3. Save. Then run:  docker compose up --build
#
#  ⚠  NEVER commit your real ".env" to git. It is already in .gitignore.
#     This ".env.example" is safe to commit — it has NO real secrets.
#
#  API KEYS AT A GLANCE:
#    ┌──────────────┬───────────┬──────────────────────────────────────────┐
#    │ Key          │ Required? │ What it powers                           │
#    ├──────────────┼───────────┼──────────────────────────────────────────┤
#    │ GROQ_API_KEY │ REQUIRED  │ AI: attack planning, vuln explanations,  │
#    │              │           │ code fixes, chatbot, attack narratives   │
#    │ OLLAMA_MODEL │ OPTIONAL  │ Local AI fallback when Groq is rate-     │
#    │              │           │ limited (needs Ollama running on host)   │
#    │ TAVILY       │ OPTIONAL  │ Accurate AI web search for the chatbot   │
#    │ VIRUSTOTAL   │ OPTIONAL  │ Threat intel: URL/IP/hash reputation     │
#    └──────────────┴───────────┴──────────────────────────────────────────┘
#
#  You only NEED a Groq key to use the scanner with AI features. Everything
#  else is optional. The scanner engines themselves work WITHOUT any key —
#  you just won't get AI explanations/fixes without Groq.
#
#  VENOM is a single-user, self-hosted tool (like OWASP ZAP or Burp on your
#  own machine) — there is no login system, no email verification, no OAuth.
# ============================================================================


# ── Database (leave as-is for Docker) ──────────────────────────────────────
# These match the docker-compose.yml services. Only change if you run your
# own external Postgres/Redis.
DATABASE_URL=postgresql://cyberuser:cyberpass@postgres:5432/cyberplatform

# ── Redis / Celery (leave as-is for Docker) ────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# ===========================================================================
#  GROQ AI  —  [REQUIRED for AI features]
# ===========================================================================
#  Groq gives you FREE, fast LLM inference. VENOM uses it for:
#    - Planning which attacks to run against a target
#    - Explaining each vulnerability in plain English
#    - Generating a working code FIX in your app's language
#    - The built-in security chatbot
#    - Attack-chain narratives ("how a hacker would exploit this")
#
#  GET A KEY (free, 2 minutes):
#    1. Go to  https://console.groq.com
#    2. Sign up (free - no credit card)
#    3. Left menu -> "API Keys" -> "Create API Key"
#    4. Copy it and paste below as GROQ_API_KEY
#
#  ── KEY ROTATION (why there are 4 slots) ─────────────────────────────────
#  Groq's free tier has PER-ACCOUNT rate limits (~1,000 requests/min).
#
#  VENOM supports up to 4 keys. It tries GROQ_API_KEY (or GROQ_API_KEY_1)
#  first; if that key is rate-limited (HTTP 429), it automatically falls
#  through to KEY_2, then KEY_3, then KEY_4. Use separate free Groq accounts
#  for each key (rate limits are per account, not per key) to multiply your
#  quota by up to 4x.
#
#  You only NEED one key (GROQ_API_KEY). The other 3 are optional - add them
#  only if you hit rate limits during heavy scanning.
#
#  ── Which model? ─────────────────────────────────────────────────────────
#  GROQ_MODEL       = the "smart" model used for planning + code fixes
#  GROQ_MODEL_FAST  = the "fast" model used for short replies + voice agent
#  Both defaults below are FREE production models on Groq. See the full list
#  at https://console.groq.com/docs/models — prefer "Production" models
#  (Preview models can be discontinued at short notice).
# ===========================================================================
GROQ_API_KEY=paste_your_groq_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MODEL_FAST=openai/gpt-oss-20b


# ===========================================================================
#  OLLAMA - Local AI Fallback  -  [OPTIONAL]
# ===========================================================================
#  When every Groq key is rate-limited, VENOM falls back to a local model
#  running on your own machine via Ollama (https://ollama.com) — chat and
#  AI explanations keep working, fully offline, at no cost.
#
#  SETUP:
#    1. Install Ollama, then:  ollama pull dolphin3
#    2. Set OLLAMA_MODEL below to match whatever you pulled.
#  Leave as default / blank if you don't want a local fallback.
# ===========================================================================
OLLAMA_MODEL=dolphin3


# ===========================================================================
#  SINGLE-USER MODE  —  [open-source default]
# ===========================================================================
#  true   = No consent gate, no domain-ownership verification, no scan
#           limits. Best for running it on your own machine (like OWASP
#           ZAP / Burp) where you already control what gets scanned.
#  false  = Enforces consent + verified-domain-ownership + concurrent-scan
#           limits before each active scan. Useful if you want the extra
#           safety gates even on a single-operator install.
# ===========================================================================
SINGLE_USER_MODE=true


# ===========================================================================
#  VIRUSTOTAL - Threat Intelligence  -  [OPTIONAL]
# ===========================================================================
#  Powers the Threat Intel tab (check if a URL/IP/domain/file-hash is
#  malicious against 70+ antivirus engines). Scanner works without it.
#
#  GET A KEY (free: 500 lookups/day):
#    1. https://www.virustotal.com -> sign up
#    2. Profile icon -> "API key" -> copy -> paste below.
# ===========================================================================
VIRUSTOTAL_API_KEY=


# ===========================================================================
#  TAVILY - Accurate AI Web Search  -  [OPTIONAL]
# ===========================================================================
#  When set, the VENOM AI chat uses Tavily as its PRIMARY web search (accurate,
#  AI-optimized results + a direct answer). Without it, VENOM falls back to the
#  free Google News / HackerNews / Wikipedia search (no key needed).
#
#  GET A KEY (free: 1,000 searches/month):
#    1. https://tavily.com -> sign up
#    2. Dashboard -> copy your API key (starts with "tvly-") -> paste below.
# ===========================================================================
TAVILY_API_KEY=


# ── File Storage (leave as-is) ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
MAX_FILE_SIZE_MB=20


# ===========================================================================
#  ENVIRONMENT  -  [IMPORTANT]
# ===========================================================================
#  "development"  -> API docs at /api/docs are ENABLED (use on your laptop)
#  "production"   -> API docs are DISABLED (use when hosting publicly)
# ===========================================================================
ENV=development


# ── CORS - who is allowed to call the API (comma-separated) ────────────────
#  Dev default below is fine. In production set it to your real domain only.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000
